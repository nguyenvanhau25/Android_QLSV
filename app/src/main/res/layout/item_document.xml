<?xml version="1.0" encoding="utf-8"?>
<!-- Item: Một tài liệu môn học
     Quyền: SINH VIÊN (chỉ tải xuống, không xóa / upload) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Icon loại file -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFileIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="?attr/colorErrorContainer"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvFileType"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="PDF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnErrorContainer"
            android:gravity="center" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Tên tài liệu -->
    <TextView
        android:id="@+id/tvDocName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Slide chương 3: Kế thừa và đa hình"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/cardFileIcon"
        app:layout_constraintEnd_toStartOf="@id/btnDownload"
        app:layout_constraintBottom_toTopOf="@id/tvDocMeta" />

    <!-- Kích thước và ngày upload -->
    <TextView
        android:id="@+id/tvDocMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="2.4 MB · Đăng ngày 10/04/2026"
        android:textSize="11sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginStart="12dp"
        android:layout_marginTop="3dp"
        app:layout_constraintTop_toBottomOf="@id/tvDocName"
        app:layout_constraintStart_toEndOf="@id/cardFileIcon"
        app:layout_constraintEnd_toStartOf="@id/btnDownload"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Nút tải xuống -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDownload"
        android:layout_width="36dp"
        android:layout_height="36dp"
        style="@style/Widget.Material3.Button.IconButton"
        app:icon="@drawable/ic_download"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="?attr/colorOutlineVariant"
        android:layout_marginStart="56dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>